{
  "expo": {
    "name": "Beerva",
    "slug": "beerva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/beerva-app-icon.png",
    "scheme": "beerva",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#F5C542",
          "defaultChannel": "default"
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D121A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "Beerva uses motion access so you can tilt your phone to drink the fake beer easter egg."
      }
    },
    "android": {
      "package": "com.beerva.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D121A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "Beerva",
      "shortName": "Beerva",
      "lang": "en",
      "themeColor": "#0D121A",
      "backgroundColor": "#0D121A",
      "display": "standalone",
      "scope": "/",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ece5f8be-c0c2-4ac2-9d14-a201c26483e4"
      }
    },
    "owner": "tobiaseis"
  }
}
